# Database (required for API and seed scripts)
# Use session/direct URLs for Drizzle push; pooler URL for app runtime.
DATABASE_URL=postgresql://postgres.awiqvhyxuqjrpmyyxlrm:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.awiqvhyxuqjrpmyyxlrm:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# Supabase project
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=sb_publishable_...

# Supabase Storage (S3-compatible API for image uploads)
S3_ENDPOINT=https://[YOUR-PROJECT-REF].storage.supabase.co/storage/v1/s3
S3_REGION=ap-northeast-1
S3_ACCESS_KEY_ID=your-s3-access-key-id
S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
S3_BUCKET=uploads
# Dev only — do NOT set on Vercel production
# S3_TLS_INSECURE=true

# Clerk authentication (required for admin)
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...
# Required on Vercel (*.vercel.app or custom domain):
VITE_CLERK_PROXY_URL=/api/__clerk

# App paths
BASE_PATH=/
PORT=8080

# Frontend local dev only
WEB_PORT=19064

# --- Vercel deployment checklist ---
#
# 1. Import repo in Vercel (root directory = repo root, not artifacts/).
# 2. Framework Preset: Other (vercel.json controls build).
# 3. Add ALL variables below to Vercel → Settings → Environment Variables
#    for Production (and Preview if you want admin on preview URLs).
#
# Required on Vercel:
#   DATABASE_URL
#   DIRECT_URL
#   SUPABASE_URL
#   S3_ENDPOINT, S3_REGION, S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY, S3_BUCKET
#   CLERK_PUBLISHABLE_KEY, CLERK_SECRET_KEY
#   VITE_CLERK_PUBLISHABLE_KEY  (needed at BUILD time)
#   VITE_CLERK_PROXY_URL=/api/__clerk  (needed at BUILD time)
#   BASE_PATH=/
#   PORT=8080
#
# Optional:
#   CLERK_JWT_KEY — faster Clerk session verification
#
# 4. Clerk Dashboard → configure allowed origins:
#    - https://your-project.vercel.app
#    - https://your-custom-domain.com (if used)
#
# 5. Deploy. Verify:
#    - Site loads at /
#    - GET /api/healthz returns {"status":"ok"}
#    - Admin sign-in works
#    - Image upload returns https://...supabase.co/... URL
#
# Do NOT commit .env — set secrets only in Vercel dashboard.
